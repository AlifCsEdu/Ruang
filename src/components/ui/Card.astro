---
interface Props {
  title?: string;
  variant?: 'default' | 'highlight' | 'interactive';
  class?: string;
}

const {
  title,
  variant = 'default',
  class: className = '',
} = Astro.props;

const variantStyles: Record<string, string> = {
  default: 'bg-white',
  highlight: 'bg-accent-yellow',
  interactive: 'bg-white hover:bg-accent-yellow/30 cursor-pointer hover:translate-x-0.5 hover:translate-y-0.5 hover:shadow-[4px_4px_0px_0px_#0D0D0D]',
};

const baseStyles = 'border-4 border-ink shadow-[8px_8px_0px_0px_#0D0D0D] transition-all duration-75';
const classes = `${baseStyles} ${variantStyles[variant]} ${className}`;
---

<div class={classes}>
  {title && (
    <div class="border-b-4 border-ink px-6 py-3 font-black text-lg uppercase tracking-wider">
      {title}
    </div>
  )}
  <div class="p-6">
    <slot />
  </div>
</div>
