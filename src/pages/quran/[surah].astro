---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SURAHS } from '../../lib/quran/surahs';
import SurahReader from '../../components/quran/SurahReader.svelte';

const { surah: surahNum } = Astro.params;
const num = Number(surahNum);

if (!num || num < 1 || num > 114) {
  return Astro.redirect('/quran');
}

const surah = SURAHS.find((s) => s.number === num);
if (!surah) {
  return Astro.redirect('/quran');
}
---

<BaseLayout title={`${surah.englishName} — Al-Quran`}>
  <div class="max-w-3xl mx-auto px-4 py-8 pb-32">
    <!-- Navigation -->
    <div class="flex items-center justify-between mb-6">
      <a href="/quran" class="btn-brutal-sm text-sm">← All Surahs</a>
      <div class="flex items-center gap-2">
        {num > 1 && (
          <a href={`/quran/${num - 1}`} class="btn-brutal-sm text-sm" transition:persist>← Prev</a>
        )}
        {num < 114 && (
          <a href={`/quran/${num + 1}`} class="btn-brutal-sm text-sm" transition:persist>Next →</a>
        )}
      </div>
    </div>

    <!-- Surah Header -->
    <div class="card-brutal mb-6 text-center" transition:name={`surah-${num}`}>
      <div class="flex items-center justify-center gap-4 mb-2">
        <span class="w-12 h-12 bg-ink text-white flex items-center justify-center font-black text-lg">{num}</span>
        <div>
          <h1 class="text-2xl font-black uppercase tracking-wider">{surah.englishName}</h1>
          <p class="text-sm text-ink/60 font-bold">{surah.englishMeaning} • {surah.versesCount} ayat • {surah.revelationType === 'Meccan' ? 'Makkah' : 'Madinah'}</p>
        </div>
      </div>
      {num !== 1 && num !== 9 && (
        <p class="arabic-text text-xl mt-4" dir="rtl">بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ</p>
      )}
    </div>

    <!-- Surah Reader (Svelte 5 island) -->
    <SurahReader chapter={num} client:load>
      <div class="text-center py-16 animate-pulse">
        <p class="font-black text-ink/40 uppercase tracking-wider">Loading verses...</p>
      </div>
    </SurahReader>
  </div>
</BaseLayout>
