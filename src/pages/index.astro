---
import BaseLayout from '../layouts/BaseLayout.astro';
import DashboardEnhanced from '../components/solat/DashboardEnhanced.svelte';
import { gregorianToHijri, HIJRI_MONTHS, HIJRI_MONTHS_AR } from '../lib/hijri/hijri';

// Today's Hijri date (server-rendered)
const today = new Date();
const hijriToday = gregorianToHijri(today.getFullYear(), today.getMonth() + 1, today.getDate());
const hijriDateStr = `${hijriToday.day} ${HIJRI_MONTHS[hijriToday.month - 1]} ${hijriToday.year} AH`;
const hijriDateAr = `${hijriToday.day} ${HIJRI_MONTHS_AR[hijriToday.month - 1]} ${hijriToday.year}`;
---

<BaseLayout title="Ruang — Your Muslim Companion">
  <div class="max-w-4xl mx-auto px-4 py-6 sm:py-8" transition:name="page-home">
    <DashboardEnhanced client:load hijriDateStr={hijriDateStr} hijriDateAr={hijriDateAr} />
  </div>
</BaseLayout>
